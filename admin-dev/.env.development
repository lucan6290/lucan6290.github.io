# 开发环境配置模板
# 新环境使用：复制此文件为 .env，填入实际的 Token 等敏感值
# cp .env.development .env

# 前端开发服务器端口
VITE_PORT=14000
# 后端 API 地址
VITE_API_BASE_URL=http://localhost:15000

# Git 平台配置（请填入实际值）
# GITHUB
GITHUB_TOKEN=
GITHUB_OWNER=lucan6290
GITHUB_REPO=lucan6290.github.io
GITHUB_BRANCH=main

# GITEE
GITEE_TOKEN=
GITEE_OWNER=
GITEE_REPO=
GITEE_BRANCH=
